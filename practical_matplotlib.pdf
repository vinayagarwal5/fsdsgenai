    "plt.title(\"Multi Plot\") # Plot name \n",
    "plt.xticks(list(range(0, len(Seasons) )),Seasons, rotation = 'vertical')\n",
    "plt.legend()\n",
    "plt.savefig(\"any.jpg\")"
   ]
